<Window x:Class="LafazFlow.Windows.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LafazFlow.Windows.UI"
        Title="{Binding SettingsWindowTitle}"
        Width="860"
        Height="660"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#0F1013">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0F1013" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#14161A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#191B20" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#202329" />
        <SolidColorBrush x:Key="BorderBrushMuted" Color="#2D323A" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A6ADB7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3DCCC7" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#123B3D" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="LineHeight" Value="18" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="HelperTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="LineHeight" Value="16" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderBrush" Value="#21666A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1F4E51" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,30,0" VerticalAlignment="Center" />
                                                <Path HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,11,0"
                                                      Fill="{StaticResource TextSecondaryBrush}"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#171A20" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  RecognizesAccessKey="True" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#111318"
                                        BorderBrush="{StaticResource BorderBrushMuted}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="13,5" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#282C34" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentDarkBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#21666A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderBrush" Value="#21666A" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,2,0,10" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,0,8,12" />
        </Style>

        <Style x:Key="DarkDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DarkDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#171A20" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#202329" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#111318" />
            <Setter Property="AlternatingRowBackground" Value="#171A20" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrushMuted}" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource DarkDataGridColumnHeaderStyle}" />
            <Setter Property="CellStyle" Value="{StaticResource DarkDataGridCellStyle}" />
            <Setter Property="RowStyle" Value="{StaticResource DarkDataGridRowStyle}" />
        </Style>

        <Style TargetType="ListBox" x:Key="SidebarListStyle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ListBoxItem" x:Key="SidebarItemStyle">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1D2026" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentDarkBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionScrollStyle" TargetType="ScrollViewer">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushMuted}"
                BorderThickness="0,0,1,0"
                Padding="20">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                    <TextBlock Text="LafazFlow"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding AppVersion}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <ListBox ItemsSource="{Binding SettingsSections}"
                         SelectedItem="{Binding SelectedSection}"
                         Style="{StaticResource SidebarListStyle}"
                         ItemContainerStyle="{StaticResource SidebarItemStyle}" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" Margin="28,24,28,12">
            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource SectionScrollStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static local:SettingsSection.Overview}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="Overview" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="A quick look at the local dictation runtime and the actions you are most likely to need." Style="{StaticResource SectionSubtitleStyle}" />

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Current Runtime" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource StatusPillStyle}" Margin="0,0,0,12">
                                <TextBlock Text="{Binding RuntimeProfileStatus}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{Binding RuntimeDiagnosticsMessage}" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" Style="{StaticResource FieldLabelStyle}" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="Refresh Checks" Width="124" Click="RefreshRuntimeDiagnostics_OnClick" />
                                <Button Content="Test Microphone" Width="128" Click="TestMicrophone_OnClick" />
                                <Button Content="Test Transcription" Width="142" Click="TestTranscription_OnClick" />
                                <Button Content="Open Logs" Width="96" Click="OpenLogsFolder_OnClick" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource SectionScrollStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static local:SettingsSection.Dictation}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="Dictation" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Everyday dictation behavior. These options affect the next recording." Style="{StaticResource SectionSubtitleStyle}" />
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <CheckBox Content="Show live transcript preview" IsChecked="{Binding ShowLiveTranscriptPreview}" />
                            <CheckBox Content="Apply vocabulary corrections" IsChecked="{Binding EnableVocabularyCorrections}" />
                            <CheckBox Content="Append trailing space after paste" IsChecked="{Binding AppendTrailingSpace}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource SectionScrollStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static local:SettingsSection.Models}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="Models" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Local transcription runtime, model files, and advanced decode controls." Style="{StaticResource SectionSubtitleStyle}" />

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Runtime Mode" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Transcription Profile" Style="{StaticResource HelperTextStyle}" />
                                    <ComboBox ItemsSource="{Binding TranscriptionProfiles}" SelectedItem="{Binding TranscriptionProfile}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Backend" Style="{StaticResource HelperTextStyle}" />
                                    <ComboBox ItemsSource="{Binding WhisperBackends}" SelectedItem="{Binding WhisperBackend}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Whisper Threads" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding WhisperThreads, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Runtime Paths" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="These are advanced local paths. Change them only when replacing the local runtime or model files." Style="{StaticResource HelperTextStyle}" />
                            <TextBlock Text="Whisper CLI" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding WhisperCliPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Content="Browse" Click="BrowseWhisperCli_OnClick" />
                            </Grid>
                            <TextBlock Text="CUDA Whisper CLI" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding CudaWhisperCliPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Content="Browse" Click="BrowseCudaWhisperCli_OnClick" />
                            </Grid>
                            <TextBlock Text="Model" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Content="Browse" Click="BrowseModel_OnClick" />
                            </Grid>
                            <TextBlock Text="Quality Model" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding QualityModelPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Content="Browse" Click="BrowseQualityModel_OnClick" />
                            </Grid>
                            <CheckBox Content="Use local VAD in quality mode" IsChecked="{Binding EnableVad}" />
                            <TextBlock Text="VAD Model" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding VadModelPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Content="Browse" Click="BrowseVadModel_OnClick" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource SectionScrollStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static local:SettingsSection.Vocabulary}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="Vocabulary" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Local vocabulary hints and deterministic correction rules for words that matter to you." Style="{StaticResource SectionSubtitleStyle}" />
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Custom Vocabulary" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="One term per line. Terms are added to the local Whisper prompt." Style="{StaticResource HelperTextStyle}" />
                            <TextBox Text="{Binding CustomVocabularyTerms, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     MinHeight="140" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Custom Correction Rules" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="One rule per line: heard phrase =&gt; corrected phrase." Style="{StaticResource HelperTextStyle}" />
                            <TextBox Text="{Binding CustomCorrectionRules, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     MinHeight="140" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource SectionScrollStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static local:SettingsSection.Sound}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="Sound" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Recording feedback sounds and per-cue loudness." Style="{StaticResource SectionSubtitleStyle}" />
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <CheckBox Content="Play sound cues" IsChecked="{Binding EnableSoundCues}" />
                            <TextBlock Text="Master Volume (%)" Style="{StaticResource FieldLabelStyle}" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding SoundCueVolumePercent, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="104" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Start" VerticalAlignment="Center" />
                                <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="200" TickFrequency="25" IsSnapToTickEnabled="False" Value="{Binding SoundCueRecordingStartedVolumePercent, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="0" Grid.Column="2" Content="Test Start" Click="TestStartSoundCue_OnClick" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Stop" VerticalAlignment="Center" />
                                <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="200" TickFrequency="25" IsSnapToTickEnabled="False" Value="{Binding SoundCueTranscribingStartedVolumePercent, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="1" Grid.Column="2" Content="Test Stop" Click="TestStopSoundCue_OnClick" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Done" VerticalAlignment="Center" />
                                <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="200" TickFrequency="25" IsSnapToTickEnabled="False" Value="{Binding SoundCueCompletedVolumePercent, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="2" Grid.Column="2" Content="Test Done" Click="TestDoneSoundCue_OnClick" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Error" VerticalAlignment="Center" />
                                <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="200" TickFrequency="25" IsSnapToTickEnabled="False" Value="{Binding SoundCueErrorVolumePercent, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="3" Grid.Column="2" Content="Test Error" Click="TestErrorSoundCue_OnClick" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource SectionScrollStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static local:SettingsSection.Clipboard}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="Clipboard" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Paste behavior and clipboard restore timing." Style="{StaticResource SectionSubtitleStyle}" />
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <CheckBox Content="Restore clipboard after paste" IsChecked="{Binding RestoreClipboardAfterPaste}" />
                            <TextBlock Text="Clipboard Restore Delay (ms)" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding ClipboardRestoreDelayMs, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource SectionScrollStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static local:SettingsSection.Diagnostics}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="Diagnostics" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Runtime checks, latency traces, and local diagnostic folders." Style="{StaticResource SectionSubtitleStyle}" />

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Runtime Status" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding RuntimeProfileStatus}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding RuntimeDiagnosticsMessage}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding RuntimeDiagnosticRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeRows="False"
                                      Height="128">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Check" Binding="{Binding Name}" Width="130" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70" />
                                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <WrapPanel>
                                <Button Content="Refresh Checks" Width="124" Click="RefreshRuntimeDiagnostics_OnClick" />
                                <Button Content="Test Microphone" Width="128" Click="TestMicrophone_OnClick" />
                                <Button Content="Test Transcription" Width="142" Click="TestTranscription_OnClick" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Recent Latency" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding LatencyDiagnosticsMessage}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding LatestLatencySummary}" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6" />
                            <DataGrid ItemsSource="{Binding RecentLatencyRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeRows="False"
                                      Height="180">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="78" />
                                    <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="92" />
                                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="130" />
                                    <DataGridTextColumn Header="Hotkey" Binding="{Binding HotkeyToVisibleMs}" Width="64" />
                                    <DataGridTextColumn Header="Queue" Binding="{Binding QueueWaitMs}" Width="64" />
                                    <DataGridTextColumn Header="Whisper" Binding="{Binding WhisperMs}" Width="70" />
                                    <DataGridTextColumn Header="Paste" Binding="{Binding PasteMs}" Width="64" />
                                    <DataGridTextColumn Header="Hide" Binding="{Binding UiHideMs}" Width="58" />
                                    <DataGridTextColumn Header="Total" Binding="{Binding TotalStopToDoneMs}" Width="70" />
                                    <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <WrapPanel>
                                <Button Content="Refresh" Width="86" Click="RefreshLatency_OnClick" />
                                <Button Content="Open Logs" Width="92" Click="OpenLogsFolder_OnClick" />
                                <Button Content="Clear Latency" Width="106" Click="ClearLatency_OnClick" />
                            </WrapPanel>
                            <CheckBox Content="Keep recordings for diagnostics" IsChecked="{Binding KeepRecordingsForDiagnostics}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource SectionScrollStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static local:SettingsSection.About}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="About" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Local folders and maintenance actions." Style="{StaticResource SectionSubtitleStyle}" />
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Version" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding AppVersion}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Settings Folder" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding SettingsFolder, Mode=OneWay}" IsReadOnly="True" />
                                <Button Grid.Column="1" Content="Open" Click="OpenSettingsFolder_OnClick" />
                            </Grid>
                            <TextBlock Text="Logs Folder" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding LogsFolder, Mode=OneWay}" IsReadOnly="True" />
                                <Button Grid.Column="1" Content="Open" Click="OpenLogsFolder_OnClick" />
                            </Grid>
                            <TextBlock Text="Recordings Folder" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding RecordingsFolder, Mode=OneWay}" IsReadOnly="True" />
                                <Button Grid.Column="1" Content="Open" Click="OpenRecordingsFolder_OnClick" />
                            </Grid>
                            <Button Content="Reset Settings" Width="118" Click="ResetSettings_OnClick" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#111318"
                BorderBrush="{StaticResource BorderBrushMuted}"
                BorderThickness="0,1,0,0"
                Padding="28,12">
            <Grid>
                <TextBlock Text="{Binding ValidationMessage}"
                           Foreground="#FFB4AB"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Width="86"
                            Click="Cancel_OnClick" />
                    <Button Content="Save"
                            Width="86"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Save_OnClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
