<Window x:Class="LafazFlow.Windows.UI.MiniRecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:LafazFlow.Windows.UI"
        Width="300"
        Height="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Window.Resources>
        <DropShadowEffect x:Key="RecorderShadow"
                          BlurRadius="18"
                          ShadowDepth="4"
                          Direction="270"
                          Opacity="0.38"
                          Color="#000000" />
    </Window.Resources>
    <Grid>
        <Border x:Name="LiveTranscriptOverlay"
                Width="{x:Static ui:MiniRecorderVisualSpec.LiveTranscriptOverlayWidth}"
                Height="{x:Static ui:MiniRecorderVisualSpec.LiveTranscriptOverlayHeight}"
                Padding="14,6"
                Background="#E6000000"
                BorderBrush="#18FFFFFF"
                BorderThickness="0.5"
                CornerRadius="12"
                Effect="{StaticResource RecorderShadow}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,52"
                Opacity="0"
                IsHitTestVisible="False">
            <TextBlock Text="{Binding PartialTranscript}"
                       Foreground="#CCFFFFFF"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"
                       MaxHeight="32" />
        </Border>

        <Border x:Name="RecorderShell"
                Width="{x:Static ui:MiniRecorderVisualSpec.BalancedCompactWidth}"
                MinWidth="{x:Static ui:MiniRecorderVisualSpec.CompactWidth}"
                MaxWidth="{x:Static ui:MiniRecorderVisualSpec.CompactMaxWidth}"
                Height="40"
                CornerRadius="20"
                Background="#F0000000"
                BorderBrush="#18FFFFFF"
                BorderThickness="0.5"
                Effect="{StaticResource RecorderShadow}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                MouseLeftButtonDown="RecorderShell_OnMouseLeftButtonDown"
                MouseRightButtonUp="RecorderShell_OnMouseRightButtonUp">
            <Grid ClipToBounds="True">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="92" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="OK"
                               Foreground="#7FFFFFFF"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0,0,12,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" />

                    <ItemsControl Grid.Column="1"
                                  x:Name="Visualizer"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <ItemsControl Grid.Column="1"
                                  x:Name="ProcessingDots"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <TextBlock Grid.Column="1"
                               x:Name="StatusTextBlock"
                               Text="{Binding StatusText}"
                               ToolTip="{Binding StatusDetail}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="Medium"
                               MinWidth="90"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding AppVersion}"
                               Foreground="#7FFFFFFF"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="12,0,0,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
