<Window x:Class="LafazFlow.Windows.UI.MiniRecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300"
        Height="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Border Width="260"
                MinHeight="28"
                Margin="0,0,0,48"
                Padding="12,6"
                CornerRadius="8"
                Background="#DD111111"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Visibility="{Binding HasRecentTranscripts, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding LastTranscriptPreview}"
                       Foreground="#CCFFFFFF"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="236" />
        </Border>
        <Border x:Name="RecorderShell"
                Width="184"
                Height="40"
                CornerRadius="20"
                Background="Black"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                MouseLeftButtonDown="RecorderShell_OnMouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="OK"
                           Foreground="#99FFFFFF"
                           FontSize="10"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <ItemsControl Grid.Column="1"
                              x:Name="Visualizer"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ItemsControl Grid.Column="1"
                              x:Name="ProcessingDots"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock Grid.Column="1"
                           x:Name="StatusTextBlock"
                           Text="{Binding StatusText}"
                           Foreground="White"
                           FontSize="11"
                           FontWeight="Medium"
                           MinWidth="90"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="2"
                           Text="AI"
                           Foreground="#99FFFFFF"
                           FontSize="10"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
